PORT=8787
DATA_DIR=./data
PUBLIC_BASE_URL=https://www.yiyeguizhen.com/gtxp

# Run background scheduler in the same process.
AUTO_RUN=false
RUN_INTERVAL_MINUTES=60
MAX_TASKS_PER_TICK=2

# Browser automation.
HEADLESS=true
CRAWLER_TIMEOUT_MS=45000
CRAWLER_SLOW_MO_MS=0
BROWSER_USER_DATA_DIR=./data/browser-profile

# Optional AI analysis. If absent, the service uses deterministic fallback scoring.
AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-5-mini
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional simple write protection. If set, mutating requests must include x-gtxp-key.
GTXP_API_KEY=
